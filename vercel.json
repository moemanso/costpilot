{
  "builds": [
    {
      "src": "public",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/public/landing.html"
    },
    {
      "src": "/chat",
      "dest": "/public/index.html"
    },
    {
      "src": "/dashboard",
      "dest": "/public/dashboard.html"
    },
    {
      "src": "/settings",
      "dest": "/public/settings.html"
    }
  ]
}
