{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/chat", "destination": "/index.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/settings", "destination": "/settings.html" },
    { "source": "/(.*)", "destination": "/landing.html" }
  ]
}
