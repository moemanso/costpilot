{
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/", "dest": "/public/landing.html" },
    { "src": "/chat", "dest": "/public/index.html" },
    { "src": "/dashboard", "dest": "/public/dashboard.html" },
    { "src": "/settings", "dest": "/public/settings.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
